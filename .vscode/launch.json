{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against Expo Web (Port 8081)",
            "url": "http://localhost:8081",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost:8084",
            "url": "http://localhost:8084",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true
        },
        {
            "type": "chrome",
            "request": "attach",
            "name": "Attach to Chrome (Port 9222)",
            "port": 9222,
            "webRoot": "${workspaceFolder}"
        }
    ]
}