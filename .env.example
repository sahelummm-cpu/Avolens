# --- Supabase backend (accounts, cloud sync, AI scan + coach) -----------
# Project URL + anon key: Supabase dashboard -> Settings -> API.
# Use the legacy anon (JWT) key so edge functions with JWT verification work.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Fallback AI scan backend (only used when Supabase is NOT configured) --
# Base URL of the deployed AvoLens web app; the mobile scanner calls
# `${EXPO_PUBLIC_API_URL}/api/scan` for AI nutrition estimates.
# Example: https://avolens.vercel.app  (or http://192.168.x.x:3000 for local dev)
EXPO_PUBLIC_API_URL=
