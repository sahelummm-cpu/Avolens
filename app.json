{
  "expo": {
    "name": "AvoLens",
    "slug": "avolens",
    "version": "0.1.0",
    "scheme": "avolens",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.avolens.mobile",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.app.avolens.mobile"
        ]
      },
      "infoPlist": {
        "NSCameraUsageDescription": "AvoLens uses the camera to scan your meals and estimate their nutrition."
      }
    },
    "android": {
      "package": "app.avolens.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#f5f7f3",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_EXERCISE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "AvoLens uses the camera to scan your meals and estimate their nutrition."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#111116"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "AvoLens uses your photos to add progress pictures.",
          "cameraPermission": "AvoLens uses the camera to take progress pictures."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/avo-logo.png",
          "imageWidth": 140,
          "backgroundColor": "#f5f7f3"
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "AvoLens reads your activity (energy burned, steps, and workouts) to show your exercise stats.",
          "background": false
        }
      ],
      "react-native-health-connect",
      "./plugins/withHealthConnectDelegate.js",
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "AvoLens uses the microphone so you can log meals by voice.",
          "speechRecognitionPermission": "AvoLens uses speech recognition so you can log meals by voice."
        }
      ],
      "@bacons/apple-targets",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "AvoLensSummary",
              "label": "AvoLens",
              "description": "Calories left and macros at a glance.",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "previewImage": "./assets/images/avo-logo.png"
            },
            {
              "name": "AvoLensStreak",
              "label": "AvoLens Streak",
              "description": "Your current logging streak.",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "none",
              "previewImage": "./assets/images/avo-logo.png"
            },
            {
              "name": "AvoLensWater",
              "label": "AvoLens Water",
              "description": "Water logged today.",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "none",
              "previewImage": "./assets/images/avo-logo.png"
            }
          ]
        }
      ]
    ]
  }
}